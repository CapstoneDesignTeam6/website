# ===================================
# Supabase 데이터베이스 설정
# ===================================
# Supabase 프로젝트에서 다음 정보를 얻을 수 있습니다:
# 1. Supabase 대시보드 (https://supabase.com) 로그인
# 2. 프로젝트 선택 → Settings → Database
# 3. Connection pooling 활성화 (PgBouncer)
# 4. Connection string 복사

# PostgreSQL 연결 문자열
# 형식: postgresql://[user]:[password]@[host]:[port]/[database]
# 예: postgresql://postgres.abcxyz:password@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.XXXXXX:your_password_here@db.supabase.co:5432/postgres

# ===================================
# JWT 설정
# ===================================
# 강력한 시크릿 키 생성 방법:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ===================================
# 네이버 API 설정 (선택사항)
# ===================================
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ===================================
# AI 서버 설정 (별도 담당자가 각각 운영)
# ===================================
# 1. 토론 진행 AI 서버 (포트 8001)
#    - 역할: 토론 주제에 대한 에이전트 응답 생성
#    - 담당자: 에이전트 개발 팀
DISCUSSION_AGENT_URL=http://localhost:8001

# 2. 토론 평가 AI 서버 (포트 8002)
#    - 역할: 토론 응답의 논리성, 일관성, 깊이 평가
#    - 담당자: 평가 시스템 개발 팀
EVALUATION_AGENT_URL=http://localhost:8002

# 에이전트 응답 타임아웃 (초)
AGENT_TIMEOUT=30

# ===================================
# 모델 설정
# ===================================
MAX_NEW_TOKENS=150
TEMPERATURE=0.7

# ===================================
# 앱 설정
# ===================================
DEBUG=True
